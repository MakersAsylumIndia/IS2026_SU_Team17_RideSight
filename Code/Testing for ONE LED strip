#include <Adafruit_NeoPixel.h> // Include the NeoPixel library

#define LED_PIN     5   // ESP32 GPIO pin connected to DI on the ring
#define NUM_LEDS    8   // Total number of LEDs in your circular ring
#define BRIGHTNESS  50  // Set brightness level (0 to 255)

// Initialize the NeoPixel object
Adafruit_NeoPixel ring(NUM_LEDS, LED_PIN, NEO_GRB + NEO_KHZ800);

void setup() {
  ring.begin();           // Initialize the hardware data pin
  ring.setBrightness(BRIGHTNESS); 
  ring.show();            // Turn off all pixels immediately
}

void loop() {
  // 1. Red Chase Effect
  circularChase(ring.Color(255, 0, 0), 100); 
  
  // 2. Green Chase Effect
  circularChase(ring.Color(0, 255, 0), 100); 
  
  // 3. Blue Chase Effect
  circularChase(ring.Color(0, 0, 255), 100); 

  // 4. Smooth Rainbow Wheel
  rainbowCycle(20);
}

// Custom function to chase a single color around the 8-bit ring
void circularChase(uint32_t color, int delayTime) {
  for (int i = 0; i < NUM_LEDS; i++) {
    ring.clear();                          // Turn off the previous LED
    ring.setPixelColor(i, color);          // Illuminate current LED
    ring.show();                           // Push the data to the ring
    delay(delayTime);
  }
}

// Custom function for a cycling rainbow wheel effect
void rainbowCycle(int delayTime) {
  for (long firstPixelHue = 0; firstPixelHue < 5 * 65536; firstPixelHue += 256) {
    for (int i = 0; i < ring.numPixels(); i++) {
      int pixelHue = firstPixelHue + (i * 65536L / ring.numPixels());
      ring.setPixelColor(i, ring.gamma32(ring.ColorHSV(pixelHue)));
    }
    ring.show();
    delay(delayTime);
  }
}
