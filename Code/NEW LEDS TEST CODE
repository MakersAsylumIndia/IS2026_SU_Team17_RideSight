#include <Adafruit_NeoPixel.h>

// Define the independent ESP32 pins
#define PIN_MOD1     5   // First LED module
#define PIN_MOD2     18  // Second LED module
#define PIN_MOD3     19  // Third LED module

#define NUM_LEDS      1  // Each pin controls exactly 1 LED module
#define BRIGHTNESS   50  // Safe brightness limit for testing

// Create individual control objects for each pin
Adafruit_NeoPixel mod1(NUM_LEDS, PIN_MOD1, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel mod2(NUM_LEDS, PIN_MOD2, NEO_GRB + NEO_KHZ800);
Adafruit_NeoPixel mod3(NUM_LEDS, PIN_MOD3, NEO_GRB + NEO_KHZ800);

void setup() {
  // Initialize Module 1
  mod1.begin();
  mod1.setBrightness(BRIGHTNESS);
  mod1.show();

  // Initialize Module 2
  mod2.begin();
  mod2.setBrightness(BRIGHTNESS);
  mod2.show();

  // Initialize Module 3
  mod3.begin();
  mod3.setBrightness(BRIGHTNESS);
  mod3.show();
}

void loop() {
  // --- STEP 1: Turn all modules RED ---
  mod1.setPixelColor(0, mod1.Color(255, 0, 0));
  mod2.setPixelColor(0, mod2.Color(255, 0, 0));
  mod3.setPixelColor(0, mod3.Color(255, 0, 0));
  showAll();
  delay(800);

  // --- STEP 2: Turn all modules GREEN ---
  mod1.setPixelColor(0, mod1.Color(0, 255, 0));
  mod2.setPixelColor(0, mod2.Color(0, 255, 0));
  mod3.setPixelColor(0, mod3.Color(0, 255, 0));
  showAll();
  delay(800);

  // --- STEP 3: Turn all modules BLUE ---
  mod1.setPixelColor(0, mod1.Color(0, 0, 255));
  mod2.setPixelColor(0, mod2.Color(0, 0, 255));
  mod3.setPixelColor(0, mod3.Color(0, 0, 255));
  showAll();
  delay(800);

  // --- STEP 4: Blink sequentially (Chase Effect) ---
  clearAll();
  
  mod1.setPixelColor(0, mod1.Color(255, 255, 255)); // White
  mod1.show();
  delay(300);
  mod1.clear();
  mod1.show();

  mod2.setPixelColor(0, mod2.Color(255, 255, 255)); // White
  mod2.show();
  delay(300);
  mod2.clear();
  mod2.show();

  mod3.setPixelColor(0, mod3.Color(255, 255, 255)); // White
  mod3.show();
  delay(300);
  mod3.clear();
  mod3.show();
}

// Helper function to update all hardware outputs at once
void showAll() {
  mod1.show();
  mod2.show();
  mod3.show();
}

// Helper function to turn off all modules
void clearAll() {
  mod1.clear();
  mod2.clear();
  mod3.clear();
  showAll();
}
